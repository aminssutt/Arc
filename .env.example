# Arc — environment template. Copy to .env and fill locally. NEVER commit .env.
# The repo is PUBLIC: every value here MUST stay blank. Real keys are shared
# off-repo (see CONTRIBUTING.md).

# --- Vultr Serverless Inference (agentic lane) ---
# Account/control-plane key (VultronRetriever, account ops).
VULTR_API_KEY=
# Inference key used by agents/common/vultr.py for chat completions.
VULTR_INFERENCE_API_KEY=
# Shared-pool guard: max concurrent inference requests per process (default 2).
VULTR_MAX_CONCURRENCY=
# Optional overrides consumed by agents/common/vultr.py:
#   VULTR_MODEL         override the pinned model (default: contracts/decisions.md)
#   VULTR_TIMEOUT       per-request timeout in seconds (default 60)
#   VULTR_INFERENCE_BASE_URL   override endpoint (default https://api.vultrinference.com/v1)
VULTR_MODEL=
VULTR_TIMEOUT=
VULTR_INFERENCE_BASE_URL=

# --- Push notifications (iOS lane) ---
# Apple Push Notification service (.p8 key contents / identifiers).
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_AUTH_KEY=

# --- Backend tool APIs (Cost / Inventory / Dispatch) ---
COST_TOOL_API_KEY=
INVENTORY_TOOL_API_KEY=
DISPATCH_TOOL_API_KEY=
