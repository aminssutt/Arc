# Arc — environment template. Copy to .env and fill locally. NEVER commit .env.
# The repo is public: every value here must stay blank unless it is a safe demo default.

# --- Backend runtime ---
ARC_HOST=0.0.0.0
ARC_PORT=8000
ARC_PUSH_MODE=file
ARC_PUSH_BUNDLE_ID=com.arc.technician
ARC_PUSH_OUT_DIR=/tmp/arc-push-out

# --- Vultr Serverless Inference ---
VULTR_API_KEY=
VULTR_INFERENCE_API_KEY=
VULTR_MAX_CONCURRENCY=
VULTR_MODEL=
VULTR_TIMEOUT=
VULTR_INFERENCE_BASE_URL=
ARC_CORPUS_COLLECTION=

# --- Push notifications / APNs ---
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.arc.technician
APNS_DEVICE_TOKEN=
APNS_AUTH_KEY_PATH=
APNS_AUTH_KEY=
APNS_ENV=sandbox

# --- Backend tool APIs ---
COST_TOOL_API_KEY=
INVENTORY_TOOL_API_KEY=
DISPATCH_TOOL_API_KEY=

# --- Web ---
NEXT_PUBLIC_ARC_BACKEND_URL=http://127.0.0.1:8000
