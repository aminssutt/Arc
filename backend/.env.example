# Arc backend — every setting is env-only (BE.1). No secrets committed, ever.
ARC_HOST=0.0.0.0
ARC_PORT=8000
# Seed data dir (defaults to /data; missing files fall back to backend/seed_defaults)
#ARC_DATA_DIR=
# Push: file (default, works everywhere) | simctl (macOS demo Mac) | apns (INT.7, flag-gated)
ARC_PUSH_MODE=file
ARC_PUSH_BUNDLE_ID=com.arc.technician
#ARC_PUSH_OUT_DIR=
ARC_HEARTBEAT_S=15
ARC_AGENT_TIMEOUT_S=120
